# =============================================================================
# summit — Discord Bot 環境変数（secrets / runtime）
# =============================================================================
# ■ 使い方
#   cp .env.example .env.local
#   cp summit.config.example.yml summit.config.yml
#   # .env.local と summit.config.yml の実値を埋める（どちらも gitignore 済み）
#   pnpm run setup               # DB 起動 → migrate → seed を一括実行
#
# ■ 検証スキーマ
#   src/env.ts（zod v4）が起動時に parse する。失敗すると process.exit(1)。
#   スキーマ定義・migration の管理は momo-db リポジトリ（../momo-db/）が担う。
#   Discord guild/channel/members などの非 secret 設定は summit.config.yml で管理する。
# =============================================================================

# -----------------------------------------------------------------------------
# Discord — https://discord.com/developers/applications
# -----------------------------------------------------------------------------

# Bot トークン（Application → Bot → "Reset Token" で取得）
# 形式: 文字列（通常 70〜80 文字、ドット区切り 3 パート）
# 注意: ログ・コード・PR に絶対に載せない。漏洩時は即 Regenerate する。
DISCORD_TOKEN=replace-with-bot-token

# -----------------------------------------------------------------------------
# データベース（PostgreSQL）
# -----------------------------------------------------------------------------

# アプリ接続用 URL（pooled。Neon 本番では pooler エンドポイントを使う）
# ローカル Docker: momo-db の compose.yaml（ポート 5433）のデフォルト値に合わせた値をそのまま使える
# Neon 本番例: postgres://user:pass@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://summit:summit@localhost:5433/summit

# -----------------------------------------------------------------------------
# 設定ファイル・タイムゾーン
# -----------------------------------------------------------------------------

# タイムゾーン固定。"Asia/Tokyo" 以外を設定すると起動時に exit(1) になる。
TZ=Asia/Tokyo

# package.json scripts は summit.config.yml を読み、SUMMIT_CONFIG_YAML に詰めてアプリへ渡す。
# アプリ本体は SUMMIT_CONFIG_YAML だけを読み、YAML ファイルは直接読まない。
# Fly 本番では summit.config.production.yml の本文を secret として直接設定する。
# ローカルでは package.json scripts が自動設定するため空のままでよい。
SUMMIT_CONFIG_YAML=

# -----------------------------------------------------------------------------
# 死活監視（任意）
# -----------------------------------------------------------------------------

# healthchecks.io 等の ping URL。設定すると node-cron の毎分 tick 内で GET リクエストを送る。
# 空文字列または未設定の場合は ping を送らない（no-op）。未設定で起動は止まらない。
# 例: https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HEALTHCHECK_PING_URL=

# コミット追跡用 SHA（任意）。
# Fly.io は FLY_IMAGE_REF を自動挿入するため通常不要。CI で別途 inject する場合に使う。
# startup.ready ログの commitSha フィールドに反映される。FLY_IMAGE_REF が優先。
GIT_SHA=
