# =============================================================================
# summit — Discord Bot 環境変数
# =============================================================================
# ■ 使い方
#   cp .env.example .env.local   # 実値を埋める（.env.local は gitignore 済み）
#   pnpm run setup               # DB 起動 → migrate → seed を一括実行
#
# ■ 検証スキーマ
#   src/env.ts（zod v4）が起動時に parse する。失敗すると process.exit(1)。
#   DIRECT_URL は drizzle.config.ts 専用で src/env.ts には含まれない。
# =============================================================================

# -----------------------------------------------------------------------------
# Discord — https://discord.com/developers/applications
# -----------------------------------------------------------------------------

# Bot トークン（Application → Bot → "Reset Token" で取得）
# 形式: 文字列（通常 70〜80 文字、ドット区切り 3 パート）
# 注意: ログ・コード・PR に絶対に載せない。漏洩時は即 Regenerate する。
DISCORD_TOKEN=replace-with-bot-token

# Bot を稼働させる Discord サーバー（Guild）の ID
# 取得: Discord で開発者モードを ON（設定 → 詳細設定）→ サーバー名を右クリック →「IDをコピー」
# 形式: 17〜20 桁の数字のみ
DISCORD_GUILD_ID=111111111111111111

# 出欠確認を投稿する専用チャンネルの ID
# 取得: チャンネル名を右クリック →「IDをコピー」
# 形式: 17〜20 桁の数字のみ
DISCORD_CHANNEL_ID=222222222222222222

# 固定 4 名の Discord User ID（カンマ区切り・スペース不要・ちょうど 4 件）
# 取得: 対象ユーザーを右クリック →「IDをコピー」
# 形式: 17〜20 桁の数字をカンマで 4 つ並べる（例: id1,id2,id3,id4）
# 注意: 4 件ちょうどでなければ起動時に exit(1) になる
MEMBER_USER_IDS=333333333333333333,444444444444444444,555555555555555555,666666666666666666

# -----------------------------------------------------------------------------
# データベース（PostgreSQL）
# -----------------------------------------------------------------------------

# アプリ接続用 URL（pooled。Neon 本番では pooler エンドポイントを使う）
# ローカル Docker: compose.yaml のデフォルト設定（ポート 5433）に合わせた値をそのまま使える
# Neon 本番例: postgres://user:pass@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://summit:summit@localhost:5433/summit

# マイグレーション専用 URL（direct・unpooled。drizzle.config.ts のみで参照する）
# アプリコード（src/）からは絶対に参照しない。env.ts にも含まれない。
# ローカルでは DATABASE_URL と同一値で問題ない（Docker は pooler 不要）
# Neon 本番例: postgres://user:pass@ep-xxx.region.neon.tech/neondb?sslmode=require
DIRECT_URL=postgres://summit:summit@localhost:5433/summit

# -----------------------------------------------------------------------------
# タイムゾーン・時刻（変更禁止）
# -----------------------------------------------------------------------------

# タイムゾーン固定。"Asia/Tokyo" 以外を設定すると起動時に exit(1) になる。
TZ=Asia/Tokyo

# 順延確認の回答期限。"24:00" のみサポート（= 候補日翌日 00:00 JST）。
# "25:00" など 24 超え表記は非対応。この値を変更してはならない。
POSTPONE_DEADLINE=24:00

# -----------------------------------------------------------------------------
# 死活監視（任意）
# -----------------------------------------------------------------------------

# healthchecks.io 等の ping URL。設定すると node-cron の毎分 tick 内で GET リクエストを送る。
# 空文字列または未設定の場合は ping を送らない（no-op）。未設定で起動は止まらない。
# 例: https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
HEALTHCHECK_PING_URL=
