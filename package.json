{
  "name": "summit",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord Bot for weekly Momotetsu attendance automation",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "dotenv -e .env.local -- tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "dotenv -e .env.local -- node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint . --tsconfig tsconfig.json --deny-warnings",
    "lint:fix": "oxlint . --tsconfig tsconfig.json --fix",
    "test": "vitest run --passWithNoTests",
    "test:integration": "INTEGRATION_DB=1 dotenv -e .env.local -- vitest run --config vitest.integration.config.ts",
    "ci": "pnpm typecheck && pnpm lint && pnpm test && pnpm build && pnpm db:check && pnpm verify:forbidden",
    "db:up": "docker compose up -d postgres",
    "db:down": "docker compose down",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:migrate": "dotenv -e .env.local -- drizzle-kit migrate",
    "db:check": "dotenv -e .env.local -- drizzle-kit check",
    "verify:forbidden": "bash scripts/verify/forbidden-patterns.sh",
    "verify:drift": "bash scripts/verify/migration-drift.sh",
    "db:seed": "dotenv -e .env.local -- tsx src/db/seed.ts",
    "db:reset": "dotenv -e .env.local -- tsx src/db/devReset.ts",
    "commands:sync": "dotenv -e .env.local -- tsx src/commands/sync.ts",
    "setup": "pnpm install && pnpm db:up && pnpm db:migrate && pnpm db:seed"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "dependencies": {
    "date-fns": "^4.1.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "neverthrow": "^8.2.0",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "postgres": "^3.4.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "oxlint": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
